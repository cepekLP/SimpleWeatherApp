{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Flutter: Debug Chrome (ask API key)",
      "request": "launch",
      "type": "dart",
      "program": "lib/main.dart",
      "flutterMode": "debug",
      "deviceId": "chrome",
      "toolArgs": [
        "--dart-define=OPENWEATHER_API_KEY=${input:openWeatherApiKey}"
      ],
      "preLaunchTask": "Flutter: pub get"
    },
    {
      "name": "Flutter: Debug Windows (ask API key)",
      "request": "launch",
      "type": "dart",
      "program": "lib/main.dart",
      "flutterMode": "debug",
      "deviceId": "windows",
      "toolArgs": [
        "--dart-define=OPENWEATHER_API_KEY=${input:openWeatherApiKey}"
      ],
      "preLaunchTask": "Flutter: pub get"
    }
  ],
  "inputs": [
    {
      "id": "openWeatherApiKey",
      "type": "promptString",
      "description": "OpenWeather API key",
      "password": true
    }
  ]
}