{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Flutter: clean build artifacts",
      "type": "shell",
      "command": "powershell",
      "args": [
        "-NoProfile",
        "-ExecutionPolicy",
        "Bypass",
        "-Command",
        "& \"$env:USERPROFILE\\.puro\\envs\\weatherenv\\flutter\\bin\\flutter.bat\" clean"
      ],
      "problemMatcher": []
    },
    {
      "label": "Flutter: pub get",
      "type": "shell",
      "command": "powershell",
      "args": [
        "-NoProfile",
        "-ExecutionPolicy",
        "Bypass",
        "-Command",
        "& \"$env:USERPROFILE\\.puro\\envs\\weatherenv\\flutter\\bin\\flutter.bat\" pub get"
      ],
      "problemMatcher": []
    },
    {
      "label": "Flutter: run",
      "type": "shell",
      "command": "powershell",
      "args": [
        "-NoProfile",
        "-ExecutionPolicy",
        "Bypass",
        "-Command",
        "& \"$env:USERPROFILE\\.puro\\envs\\weatherenv\\flutter\\bin\\flutter.bat\" run -d ${input:flutterDevice}"
      ],
      "problemMatcher": [],
      "dependsOn": [
        "Flutter: pub get"
      ],
      "dependsOrder": "sequence"
    },
    {
      "label": "Flutter: analyze",
      "type": "shell",
      "command": "powershell",
      "args": [
        "-NoProfile",
        "-ExecutionPolicy",
        "Bypass",
        "-Command",
        "& \"$env:USERPROFILE\\.puro\\envs\\weatherenv\\flutter\\bin\\flutter.bat\" analyze"
      ],
      "problemMatcher": []
    },
    {
      "label": "Flutter: test",
      "type": "shell",
      "command": "powershell",
      "args": [
        "-NoProfile",
        "-ExecutionPolicy",
        "Bypass",
        "-Command",
        "& \"$env:USERPROFILE\\.puro\\envs\\weatherenv\\flutter\\bin\\flutter.bat\" test"
      ],
      "problemMatcher": []
    }
  ],
  "inputs": [
    {
      "id": "flutterDevice",
      "type": "pickString",
      "description": "Target device",
      "options": [
        "windows",
        "edge"
      ],
      "default": "windows"
    }
  ]
}